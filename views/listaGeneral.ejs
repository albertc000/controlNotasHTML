<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista General</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .grupo { margin-bottom: 1rem; }
        label { display: block; margin-bottom: 0.5rem; font-weight: bold; color: #1a3a5c; }
        input { 
            width: 100%; 
            padding: 0.75rem; 
            border: 1px solid #ccc; 
            border-radius: 4px; 
            font-size: 1rem;
            font-family: inherit;
        }
        input:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.2); }
        form button { margin-top: 1rem; width: 100%; font-weight: bold; font-size: 1.1rem; }
        table { border-collapse: separate;  border-spacing: 0px 10px}
        th { padding: 00px 30px; }

    </style>
</head>
<body>
    <header>
        <h1>Lista de Alumnos</h1>
        <p>Lista de estudiantes del sistema</p>
    </header>

    <main>
        <section class="card">
            <h2>Datos de los Estudiantes</h2>

            <table class="table table-inverse">
                <thead>
                    <tr>
                        <th>ci</th>
                        <th>nombre</th>
                        <th>apellido</th>
                        <th>nota 1</th>
                        <th>nota 2</th>
                        <th>nota 3</th>
                        <th>nota 4</th>
                    </tr>
                </thead>

                <tbody>
                    <% for(var i=0; i < estudiantes.length; i++) { %>
                        <tr>
                            <td><%= estudiantes[i].ci %></td>
                            <td><%= estudiantes[i].nombre %></td>
                            <td><%= estudiantes[i].apellido %></td>
                            <td><%= estudiantes[i].nota1 %></td>
                            <td><%= estudiantes[i].nota2 %></td>
                            <td><%= estudiantes[i].nota3 %></td>
                            <td><%= estudiantes[i].nota4 %></td>
                        </tr>
                    <% } %>
                </tbody>
            </table>

        </section>

        <section class="card">
            <ul>
                <li><a href="/">⬅ Volver al inicio</a></li>
            </ul>
        </section>
    </main>

    <footer>
        <p>Programación II · Trayecto II · UPTT</p>
    </footer>
</body>
</html>
