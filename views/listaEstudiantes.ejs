<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Estudiante</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="navbar" role="banner">
    <div class="search-form-container">
        <form class="search-form" action="/busquedaAlumno" method="POST">
            <label for="ci" class="sr-only">Búsqueda</label>
            <input class="search-form-input" type="number" id="ci" name="ci" placeholder="Búsqueda de un Estudiante...">

            <button class="search-form-button" type="submit" aria-label="Search">
                <!-- Magnifying glass SVG icon -->
                <svg class="lupa" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" fill="none">
                    <path class="lupa" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" fill="currentColor"/>
                </svg>
            </button>
        </form>
    </div>
        <div class="navbar__container">
            <a href="#" class="navbar__brand">Control de Notas</a>
            
            <nav id="navbarMenu" class="navbar__menu" role="navigation" aria-labelledby="navbarToggle">
                <ul class="navbar__list">
                    <li class="navbar__item"><a href="/" class="navbar__link">Inicio</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="solid-container-2">
        <a class="titulo">Lista de Estudiantes</a>
        <button class="action-button" id="btn-recargar" onclick="cargarEstudiantes()">
            <svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.651 7.65a7.131 7.131 0 0 0-12.68 3.15M18.001 4v4h-4m-7.652 8.35a7.13 7.13 0 0 0 12.68-3.15M6 20v-4h4"/>
            </svg>
        </button>
    </div>
    <div class="solid-container-2">
        <a href="/registro"><button type="button" id="añadir-btn" class="solid-btn-1">Registrar Estudiante</button></a>
        
    </div>
    <table class="actions-table" id="myActionsTable">
        <thead>
            <tr>
                <th scope="col">Cédula</th>
                <th scope="col">Nombre</th>
                <th scope="col">Apellido</th>
                <th scope="col">Primera Nota</th>
                <th scope="col">Segunda Nota</th>
                <th scope="col">Tercera Nota</th>
                <th scope="col">Cuarta Nota</th>
                <th scope="col">Promedio</th>
                <th scope="col" class="cell-actions">Acciones</th>
            </tr>
        </thead>
        <tbody id="cuerpoTabla">

        </tbody>
    </table>

    <div class="solid-container-2">
        <a href="/"><button type="button" id="inicio-btn"  class="solid-btn-1">Volver a Inicio</button></a>
    </div>
    <script>
        //la función async permite usar await adentro
        function editarAlumno(ci) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/busquedaAlumno';
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'ci';
            input.value = ci;
            form.appendChild(input);
            document.body.appendChild(form);
            form.submit();
        }

        async function eliminarAlumno(ci, nombre) {
            const confirmar = confirm(`¿Eliminar a ${nombre}?`);
            if (!confirmar) return;
            const respuesta = await fetch('/eliminarAlumno', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ci: ci })
            });
            if (respuesta.ok) {
                cargarEstudiantes();
            } else {
                alert('Error al eliminar el estudiante');
            }
        }

        async function cargarEstudiantes() {
            //fetch hace la petición http al servidor
            //await pausa la función hasta que el servidor responda
            const respuesta = await fetch('/api/estudiantes');
            //.json() convierte la respuesta en un array de objetos JS
            const estudiantes = await respuesta.json();

            const cuerpo = document.getElementById('cuerpoTabla');
            //filas con los datos recibidos
            cuerpo.innerHTML = estudiantes.map(alumno => {
                const promedio = ((alumno.nota1 + alumno.nota2 + alumno.nota3 + alumno.nota4) / 4);
                const clase = promedio >= 10 ? 'aprobado' : 'reprobado';
                return `
                    <tr>
                        <td>${alumno.ci}</td>
                        <td>${alumno.nombre}</td>
                        <td>${alumno.apellido}</td>
                        <td>${alumno.nota1}</td>
                        <td>${alumno.nota2}</td>
                        <td>${alumno.nota3}</td>
                        <td>${alumno.nota4}</td>
                        <td class="${clase}">${promedio.toFixed(2)}</td>
                        <td class="cell-actions">
                            <div class="actions-container">
                                <button class="action-button btn-edit" id="lapiz" onclick="editarAlumno(${alumno.ci})" title="Editar">
                                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"></path></svg>
                                </button>
                                <button class="action-button btn-delete" id="borrador" onclick="eliminarAlumno(${alumno.ci}, '${alumno.nombre}')" title="Eliminar">
                                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"></path></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }
        cargarEstudiantes();
    </script>
</body>
</html>
