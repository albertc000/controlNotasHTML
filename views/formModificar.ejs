<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modificar Estudiante</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="navbar" role="banner">
        <div class="navbar__container">
            <a href="#" class="navbar__brand">Control de Notas</a>
            
            <nav id="navbarMenu" class="navbar__menu" role="navigation" aria-labelledby="navbarToggle">
                <ul class="navbar__list">
                    <li class="navbar__item"><a href="#" onclick="return confirm('¿Estás seguro de que deseas salir?')" class="navbar__link">Salir</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="registration-form-container">
        <div class="registration-form-header">
            <h2>Datos del Estudiante</h2>
            <p>Buscados en la Base de Datos</p>
        </div>

        <form id="registrationForm" action="/procesarAlumno" method="POST">
            <div class="form-group">
                <label for="ci">Cédula de Identidad</label>
                <input type="number" id="ci" name="ci" min="1" max="99999999" required autocomplete="cédula" value="<%= ci %>">
            </div>

            <!-- Two-column row -->
            <div class="form-row">
                <div class="form-group">
                    <label for="nombre">Nombre</label>
                <input type="text" id="nombre" name="nombre" required autocomplete="nombre" value="<%= nombre %>">
                </div>
                <div class="form-group">
                    <label for="apellido">Apellido</label>
                <input type="text" id="apellido" name="apellido" required autocomplete="apellido" value="<%= apellido %>">
                </div>
            </div>

            <!-- Two-column row -->
            <div class="form-row">
                <div class="form-group">
                    <label for="nota1">Primera Nota</label>
                    <input type="number" min="0" max="20" id="nota1" name="nota1" required autocomplete="apellido" value="<%= nota1 %>">
                </div>
                <div class="form-group">
                    <label for="nota1">Segunda Nota</label>
                    <input type="number" min="0" max="20" id="nota2" name="nota2" required autocomplete="apellido" value="<%= nota2 %>">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="nota1">Tercera Nota</label>
                    <input type="number" min="0" max="20" id="nota3" name="nota3" required autocomplete="apellido" value="<%= nota3 %>">
                </div>
                <div class="form-group">
                    <label for="nota1">Cuarta Nota</label>
                    <input type="number" min="0" max="20" id="nota4" name="nota4" required autocomplete="apellido" value="<%= nota4 %>">
                </div>
            </div>

            <div class="form-row">
                    <div class="form-group">
                        <button type="submit" name="accion" value="actualizar" class="botonActualizar">Actualizar Estudiante</button>
                    </div>
                    <div class="form-group">
                        <button type="submit" name="accion" value="eliminar" class="botonEliminar">Eliminar Estudiante</button>   
                    </div>
            </div>
        </form>
    </div>

    <div class="solid-container-1">
        <a href="/"><button type="button" class="solid-btn-1">Volver a Inicio</button></a>
    </div>
</body>
</html>
