<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar Alumno</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="navbar" role="banner">
    <div class="search-form-container">
        <form class="search-form" action="/busquedaAlumno" method="POST">
            <label for="ci" class="sr-only">Búsqueda</label>
            <input class="search-form-input" type="number" id="ci" name="ci" placeholder="Búsqueda de un Estudiante...">

            <button class="search-form-button" type="submit" aria-label="Search">
                <!-- Magnifying glass SVG icon -->
                <svg class="lupa" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" fill="none">
                    <path class="lupa" d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" fill="currentColor"/>
                </svg>
            </button>
        </form>
    </div>
        <div class="navbar__container">
            <a href="#" class="navbar__brand">Control de Notas</a>
            
            <nav id="navbarMenu" class="navbar__menu" role="navigation" aria-labelledby="navbarToggle">
                <ul class="navbar__list">
                    <li class="navbar__item"><a href="/" class="navbar__link">Inicio</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="registration-form-container">
        <div class="registration-form-header">
            <svg id="tic" class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                <path stroke="#e74c3c" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 17.94 6M18 18 6.06 6"/>
            </svg>
            <h2>Proceso Fallido</h2>
            <p>Ha ocurrido un error con su acción</p>
            <br>
            <h2>Resumen de Datos</h2>
            <p><%= error %></p>
        </div>

    </div>
        
    <div class="solid-container-2">
        <a href="/registro"><button type="button" id="añadir-btn" class="solid-btn-1">Registrar Estudiante</button></a>
        <a href="/lista"><button type="button" id="lista-btn" class="solid-btn-1">Lista de Estudiantes</button></a>
    </div>
    <div class="solid-container-2">
        <a href="/"><button type="button" id="inicio-btn" class="solid-btn-1">Volver a Inicio</button></a>
    </div>

</body>
</html>
