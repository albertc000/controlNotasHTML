<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar Estudiante</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="navbar" role="banner">
        <div class="navbar__container">
            <a href="#" class="navbar__brand">Control de Notas</a>
            
            <nav id="navbarMenu" class="navbar__menu" role="navigation" aria-labelledby="navbarToggle">
                <ul class="navbar__list">
                    <li class="navbar__item"><a href="#" onclick="return confirm('¿Estás seguro de que deseas salir?')" class="navbar__link">Salir</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="registration-form-container">
        <div class="registration-form-header">
            <h2>Registrar un Estudiante Nuevo</h2>
            <p>Añadirlo a la Base de Datos</p>
        </div>

        <form id="registrationForm" action="/guardarAlumno" method="POST">
            <div class="form-group">
                <label for="ci">Cédula de Identidad</label>
                <input type="number" id="ci" name="ci" min="1" max="99999999" required autocomplete="cédula" placeholder="Ej: 30123456">
            </div>
            
            <div class="form-group">
                <label for="nombre">Nombre</label>
                <input type="text" id="nombre" name="nombre" required autocomplete="nombre" placeholder="Ej: Juan">
            </div>

            <div class="form-group">
                <label for="apellido">Apellido</label>
                <input type="text" id="apellido" name="apellido" required autocomplete="apellido" placeholder="Ej: Perez">
            </div>

            <button type="submit" class="submit-btn">Registrar Estudiante</button>
        </form>
    </div>

        <div class="solid-container-1">
        <a href="/"><button type="button" class="solid-btn-1">Volver a Inicio</button></a>
    </div>
</body>
</html>
